# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blogverse

# ── JWT Secret ────────────────────────────────────────────────
SECRET_KEY=your-super-secret-random-key-here

# ── Frontend URL ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Gemini AI (optional – AI features) ───────────────────────
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
# Image generation model (free tier: ~500-1500 images/day)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ── Cloudinary (optional – cloud image storage) ──────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SMTP Email (optional – for real verification emails) ─────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@blogverse.com
